# Supabase (optional — enables cross-device project storage)
# When these are set the app uses Supabase Postgres instead of local IndexedDB.
# Get these values from your Supabase project → Settings → API.
#
# SQL to create the table in your Supabase SQL editor:
#
#   create table projects (
#     id             bigint generated always as identity primary key,
#     name           text         not null,
#     description    text         not null default '',
#     created_at     timestamptz  not null default now(),
#     updated_at     timestamptz  not null default now(),
#     admin          jsonb        not null,
#     inputs         jsonb        not null,
#     dashboard_data jsonb
#   );
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ────────────────────────────────────────────────────────────────────────────
# Anthropic API (optional — enables the "Research live benchmarks" button on
# the Cost Reference cards in the inputs page).
#
# When set on the Vercel deployment, the /api/benchmarks/research serverless
# function uses Claude (Opus 4.7) with the web_search tool to fetch current
# Australian QS-published cost benchmarks (Rawlinsons, T&T ICMS, RLB, AIQS,
# etc.) tailored to the entered project metrics, and returns cited URLs.
#
# IMPORTANT: This is a SERVER-SIDE env var. Do NOT prefix with VITE_. The key
# must never be exposed to the browser. Set it in Vercel → Project →
# Settings → Environment Variables (Production / Preview / Development).
#
# If unset, the built-in static benchmark database remains fully functional —
# only the live-research button is disabled.
#
# ANTHROPIC_API_KEY=sk-ant-...
