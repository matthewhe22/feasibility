# Supabase (optional — enables cross-device project storage)
# When these are set the app uses Supabase Postgres instead of local IndexedDB.
# Get these values from your Supabase project → Settings → API.
#
# SQL to create the table in your Supabase SQL editor:
#
#   create table projects (
#     id             bigint generated always as identity primary key,
#     name           text         not null,
#     description    text         not null default '',
#     created_at     timestamptz  not null default now(),
#     updated_at     timestamptz  not null default now(),
#     admin          jsonb        not null,
#     inputs         jsonb        not null,
#     dashboard_data jsonb
#   );
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
